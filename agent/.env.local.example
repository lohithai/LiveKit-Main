# ============================================================
# Truliv Luna Bengaluru Voice AI Agent - Environment Variables
# Copy this file to .env.local and fill in your actual values
# ============================================================

# === LiveKit Server ===
LIVEKIT_URL=ws://livekit-server:7880
LIVEKIT_API_KEY=REPLACE_WITH_YOUR_API_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_YOUR_API_SECRET

# === Agent Identity ===
AGENT_NAME=truliv-telephony-agent

# === STT + TTS: Sarvam AI ===
SARVAM_API_KEY=REPLACE_WITH_YOUR_SARVAM_KEY
SARVAM_VOICE_ID=ritu

# === LLM: OpenRouter ===
OPENROUTER_API_KEY=REPLACE_WITH_YOUR_OPENROUTER_KEY

# === Google Maps API (for location check) ===
GOOGLE_API_KEY=REPLACE_WITH_YOUR_GOOGLE_KEY

# === MongoDB Atlas ===
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority

# === LeadSquared CRM ===
LEADSQUARED_ACCESS_KEY=REPLACE_WITH_YOUR_KEY
LEADSQUARED_SECRET_KEY=REPLACE_WITH_YOUR_SECRET

# === Warden API (Truliv Luna property data) ===
WARDEN_API_BASE_URL=https://truliv-cron-job.vercel.app/api
WARDEN_API_KEY=REPLACE_WITH_YOUR_KEY

# === Call Recording (S3 Storage) ===
RECORDING_S3_BUCKET=REPLACE_WITH_YOUR_S3_BUCKET
RECORDING_S3_REGION=ap-south-1
RECORDING_S3_ACCESS_KEY=REPLACE_WITH_YOUR_AWS_ACCESS_KEY
RECORDING_S3_SECRET_KEY=REPLACE_WITH_YOUR_AWS_SECRET_KEY

# === External Webhook ===
EXTERNAL_WEBHOOK_URL=
EXTERNAL_WEBHOOK_SECRET=
EXTERNAL_WEBHOOK_TIMEOUT=30
EXTERNAL_WEBHOOK_MAX_RETRIES=3
