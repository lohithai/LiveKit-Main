# ============================================================
# Marhaba Haji Voice AI Agent - Environment Variables
# Copy this file to .env.local and fill in your actual values
# ============================================================

# === LiveKit Server ===
LIVEKIT_URL=ws://127.0.0.1:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# === Agent Identity ===
AGENT_NAME=marhaba-haji

# === SIP (same trunk as Truliv) ===
SIP_TRUNK_OUTBOUND_ID=

# === STT: Sarvam AI (saaras:v3) ===
SARVAM_API_KEY=

# === TTS: Cartesia (sonic-3) ===
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# === LLM: Google Gemini ===
GOOGLE_API_KEY=

# === MongoDB Atlas (same cluster, separate DB) ===
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=marhaba_haji
MONGO_CONTEXT_COLLECTION=marhaba_context
